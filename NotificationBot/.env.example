# Use the SAME token your users have already started (e.g. the CourseBot token),
# so notifications reach them without starting a separate bot. This service only
# SENDS (no polling), so it can share a token with a bot that polls.
BOT_TOKEN=your_bot_token_here

# Must equal Laravel's NOTIFICATION_BOT_SECRET (sent as the X-Bot-Secret header)
API_SECRET=change_me_to_a_long_random_string

API_PORT=8090
