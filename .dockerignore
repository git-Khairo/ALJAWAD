# Dependencies — reinstalled inside the image, never copy the host's copies
/node_modules
/vendor

# Stale bootstrap caches from the host. THIS is what caused the production
# crash: packages.php / services.php generated on a dev machine reference
# dev-only providers (e.g. Laravel\Pail\PailServiceProvider) that don't exist
# in a `composer install --no-dev` image. Let Laravel regenerate them.
/bootstrap/cache/*.php

# Local env / secrets — supplied at runtime, must not be baked into the image
.env
.env.*
!.env.example

# VCS / CI / editor noise
.git
.gitignore
.github
.vscode
.idea

# Frontend build output — regenerated by the node build stage
/public/build
/public/hot

# Test tooling — not needed in the runtime image
/tests
/.phpunit.cache
phpunit.xml

# Sibling services — built/run separately, not part of the Laravel image
/CourseBot
/NotificationBot
/TransactionBot
