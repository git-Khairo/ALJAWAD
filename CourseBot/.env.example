# ── Bot credentials ──────────────────────────────────────────────────
BOT_TOKEN=your_bot_token_here

# ── Admin user IDs (comma-separated Telegram user IDs, NOT usernames) ─
ADMIN_IDS=123456789,987654321

# ── Channel IDs (negative numbers for supergroups/channels) ───────────
BEGINNER_CHANNEL_ID=-1001234567890
INTERMEDIATE_CHANNEL_ID=-1001234567891
EXPERT_CHANNEL_ID=-1001234567892

# ── HTTP API ──────────────────────────────────────────────────────────
# Port the FastAPI server listens on (default 8080)
API_PORT=8080
# Shared secret between Laravel and the bot — set the same value in Laravel .env as TELEGRAM_BOT_SECRET
API_SECRET=change_me_to_a_long_random_string
# Base URL of the Laravel app — used for outbound calls (e.g. auto-linking a
# client's Telegram chat id after they press START via a CSAT rating deep link).
API_BASE_URL=http://app:80
